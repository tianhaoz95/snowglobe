{
    "name": "Snowglobe Linux Dev",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "rust-lang.rust-analyzer",
                "Dart-Code.flutter",
                "ms-python.python",
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools"
            ]
        }
    },
    "remoteUser": "root",
    "mounts": [
        // Optional: Mount your QNN SDK from host to container
        // "source=${localEnv:HOME}/qnn-sdk,target=/opt/qnn-sdk,type=bind,consistency=cached"
    ],
    "containerEnv": {
        "QNN_SDK_ROOT": "/opt/qnn-sdk",
        "ANDROID_NDK_ROOT": "/opt/android-ndk"
    },
    "postCreateCommand": "git submodule update --init --recursive && pip3 install --upgrade pip setuptools wheel && pip3 install -e third_party/executorch && npm install -g @google/gemini-cli",
    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers/features/node:1": {
            "version": "lts"
        }
    }
}
